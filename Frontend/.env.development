# Configuración de desarrollo (npm start / vite dev).
# En producción NO se usa este archivo: el build Docker recibe
# VITE_API_BASE_URL vacío y nginx hace proxy de /api al backend.
VITE_API_BASE_URL=http://localhost:4000

# Client ID de OAuth de Google (pegar aqui el de Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=
