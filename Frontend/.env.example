# Copia este archivo a .env.development (dev) o .env.production (build)
# y ajusta los valores según tu entorno.

# URL base del backend Express. Vacío = mismo origen (nginx hace proxy de /api).
VITE_API_BASE_URL=http://localhost:4000

# Client ID de OAuth 2.0 de Google (el mismo que GOOGLE_CLIENT_ID del backend).
# Si se deja vacio, el boton de Google no se muestra.
VITE_GOOGLE_CLIENT_ID=
